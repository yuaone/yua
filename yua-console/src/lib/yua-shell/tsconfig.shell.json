{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "rootDir": "../",     // yua-shell + yua-c 모두 포함
    "outDir": "../../dist",
    "baseUrl": "../",

    "paths": { "*": ["./*"] }
  },

  "include": [
    "../yua-c/**/*",          // ⬅ 반드시 포함!
    "./engine/**/*",
    "./runtime/**/*",
    "./parser/**/*",
    "./tokenizer/**/*",
    "./types/**/*",
    "./server/**/*"
  ],

  "exclude": [
    "./dist",
    "./node_modules"
  ]
}
