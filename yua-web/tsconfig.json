{
  "compilerOptions": {
    /* ===============================
       Base
    =============================== */
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    /* ===============================
       Module / Resolution
    =============================== */
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    /* ===============================
       Next.js
    =============================== */
    "plugins": [
      {
        "name": "next"
      }
    ],
    /* ===============================
       Paths (🔥 SSOT 핵심)
    =============================== */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "yua-shared": [
        "../yua-shared/src/index.ts"
      ],
      "yua-shared/*": [
        "../yua-shared/src/*"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    "../yua-shared/src/types/thinkingProfile.ts",
    ".next-build/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
