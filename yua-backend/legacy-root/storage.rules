rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // MoneyAlly 앱에서 업로드하는 공식 문서만 허용
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 민감 데이터 구간은 서버에서만 접근 가능
    match /secure/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
