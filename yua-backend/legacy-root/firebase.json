{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },

  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },

  "hosting": [
    {
      "site": "moneyally-web",
      "public": "public",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],

  "storage": {
    "rules": "storage.rules"
  }
}
