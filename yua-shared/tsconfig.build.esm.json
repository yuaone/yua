{
  "compilerOptions": {
    "outDir": "dist/esm",
    "rootDir": "src",

    "declaration": true,
    "declarationDir": "dist/types",

    "emitDeclarationOnly": false,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2020",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
